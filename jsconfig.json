{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "erasableSyntaxOnly": true,
    "lib": ["esnext", "DOM"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",

    "paths": {
      "@/*": ["./scripts/*"],
      "@common/*": ["./common/*"],
      "vue": ["./common/vue.esm-browser.prod.js"]
    }
  }
}
